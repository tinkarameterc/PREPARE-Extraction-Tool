# =============================================================================
# PREPARE USAGI - Environment Configuration
# =============================================================================

# Docker configuration
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend
DOCKER_IMAGE_BIONER=bioner
TAG=latest

# Project name
PROJECT_NAME="PREPARE Usagi Tool"
STACK_NAME=prepare-usage-tool-project

# For the services to communicate with eachother
FRONTEND_HOST=http://localhost:5173
BACKEND_HOST=http://localhost:8000
EXTRACT_HOST=http://localhost:5600

# In staging and production, set this env var to the frontend host, e.g.
# FRONTEND_HOST=https://dashboard.example.com

# Backend CORS Origins - Allowed origins for cross-origin requests
# Format options:
#   1. Comma-separated: http://localhost:3000,http://localhost:8080
#   2. JSON array: ["http://localhost:3000","http://localhost:8080"]
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:5173,https://localhost,https://localhost:5173

# Environment: local, staging, production
ENVIRONMENT=local

# Security - Generate with: openssl rand -hex 32
SECRET_KEY=changethis-generate-a-secure-random-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# PostgreSQL database
POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app

# Build the database URL
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_SERVER}:${POSTGRES_PORT}/${POSTGRES_DB}
# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Models
EMBEDDING_MODEL_SENTENCE=neuml/pubmedbert-base-embeddings
EMBEDDING_MODEL_MODEL2VEC=minishlab/potion-multilingual-128M

# BioNER
BIONER_HOST_PORT=5600
BIONER_MODEL_TYPE=llm
BIONER_MODEL_PATH=model-name-or-path
BIONER_ADAPTER_PATH=
BIONER_PROMPTS_PATH=